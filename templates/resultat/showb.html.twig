{% extends 'back.html.twig' %}

{% block title %}Détails du Résultat{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1 class="mb-4 text-center" style="color: #FF8C42; font-weight: 600;">Détails du Résultat</h1> <!-- Titre en orange clair -->

        <div class="card shadow-sm p-4" style="max-width: 800px; margin: 0 auto; background-color: #F9F9F9; border: 1px solid #E0E0E0;">
            <table class="table table-striped table-hover table-bordered shadow-sm rounded">
                <tbody>
                    <tr>
                        <th scope="row" style="width: 30%;">ID</th>
                        <td>{{ resultat.id }}</td>
                    </tr>
                    <tr>
                        <th scope="row">Note</th>
                        <td>{{ resultat.note }}</td>
                    </tr>
                    <tr>
                        <th scope="row">Date de Création</th>
                        <td>{{ resultat.dateCreation ? resultat.dateCreation|date('d/m/Y') : 'N/A' }}</td>
                    </tr>
                    <tr>
                        <th scope="row">Appréciation</th>
                        <td>{{ resultat.appreciation }}</td>
                    </tr>
                    <tr>
                        <th scope="row">Évaluation</th>
                        <td>{{ resultat.Evaluation.titre }}</td>
                    </tr>
                </tbody>
            </table>

            <div class="text-center mt-4">
                <a href="{{ path('app_resultat_indexb') }}" class="btn btn-secondary me-2">
                    <i class="bi bi-arrow-left"></i> Retour à la liste
                </a>
                <a href="{{ path('app_resultat_editb', {'id': resultat.id}) }}" class="btn btn-warning me-2">
                    <i class="bi bi-pencil"></i> Modifier
                </a>
                <form action="{{ path('app_resultat_deleteb', {'id': resultat.id}) }}" method="post" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce résultat ?');" style="display: inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ resultat.id) }}">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Supprimer
                    </button>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
