{{ form_start(form, {'attr': {'class': 'form-horizontal', 'novalidate': 'novalidate'}}) }}

<div class="mb-3">
    {{ form_label(form.note, 'Note', {'label_attr': {'class': 'form-label'}}) }}
    {{ form_widget(form.note, {'attr': {'class': 'form-control', 'placeholder': 'Entrez la note'}}) }}    <div class="text-danger">{{ form_errors(form.note) }}</div>
</div>

<div class="mb-3">
    {{ form_label(form.dateCreation, 'Date de création', {'label_attr': {'class': 'form-label'}}) }}
    {{ form_widget(form.dateCreation, {'attr': {'class': 'form-control'}}) }}
    <div class="text-danger">{{ form_errors(form.dateCreation) }}</div>
</div>

<div class="mb-3">
    {{ form_label(form.appreciation, 'Appréciation', {'label_attr': {'class': 'form-label'}}) }}
    {{ form_widget(form.appreciation, {'attr': {'class': 'form-control'}}) }}
    <div class="text-danger">{{ form_errors(form.appreciation) }}</div>
</div>

<div class="mb-3">
    {{ form_label(form.Evaluation, 'Évaluation', {'label_attr': {'class': 'form-label'}}) }}
    {{ form_widget(form.Evaluation, {'attr': {'class': 'form-control'}}) }}
    <div class="text-danger">{{ form_errors(form.Evaluation) }}</div>
</div>

<div class="text-center">
    <button type="submit" class="btn btn-primary" style="background-color: #4A90E2; border-color: #4A90E2;">
        <i class="bi bi-save"></i> {{ button_label|default('Enregistrer') }}
    </button>
</div>

{{ form_end(form) }}
