<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function() {
        function setAppreciation(note) {
            if (note < 10) {
                return 'Insuffisant';
            } else if (note >= 10 && note <= 13) {
                return 'Passable';
            } else if (note > 13 && note <= 15) {
                return 'Bien';
            } else if (note > 15 && note <= 18) {
                return 'Très bien';
            } else if (note > 18) {
                return 'Excellent';
            }
        }

        // Vérifier la note en temps réel et mettre à jour l'appréciation
        $('#resultat_note').on('input', function() {
            var note = $(this).val();
            if (note >= 0 && note <= 20) {
                $('#resultat_appreciation').val(setAppreciation(note));
            } else {
                $('#resultat_appreciation').val('');
            }
        });

        // Vérification avant soumission du formulaire
        $('form').on('submit', function(event) {
            var note = $('#resultat_note').val();
            var dateCreation = $('#resultat_dateCreation').val();
            var appreciation = $('#resultat_appreciation').val();
            var evaluation = $('#resultat_evaluation').val();

            if (note === '' || dateCreation === '' || appreciation === '' || evaluation === '') {
                alert('Tous les champs doivent être remplis.');
                event.preventDefault();
                return;
            }

            if (note < 0 || note > 20) {
                alert('La note doit être entre 0 et 20.');
                event.preventDefault();
                return;
            }
        });
    });
</script>
