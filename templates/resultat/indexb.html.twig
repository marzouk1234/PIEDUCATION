{% extends 'back.html.twig' %}

{% block title %}Résultats (Back-Office){% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1 class="mb-4 text-center" style="color: #FF8C42; font-weight: 600;">Liste des Résultats</h1>

        <table class="table table-striped table-hover table-bordered shadow-sm rounded" style="background-color: #F9F9F9; border-color: #E0E0E0;">
            <thead class="text-center" style="background-color: #5A9FD6; color: #FFFFFF;">
                <tr>
                    <th scope="col">Note</th>
                    <th scope="col">Date de Création</th>
                    <th scope="col">Appréciation</th>
                    <th scope="col">Évaluation</th>
                    <th scope="col" style="width: 200px;">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for resultat in resultats %}
                <tr class="align-middle">
                    <td class="text-center">{{ resultat.note }}</td>
                    <td class="text-center">{{ resultat.dateCreation ? resultat.dateCreation|date('d/m/Y') : 'N/A' }}</td>
                    <td class="text-center">{{ resultat.appreciation }}</td>
                    <td class="text-center">{{ resultat.Evaluation.titre }}</td>
                    <td class="text-center" style="width: 200px;">
                        <div class="d-flex justify-content-center">
                            <a href="{{ path('app_resultat_showb', {'id': resultat.id}) }}" class="btn btn-info btn-sm me-1" style="background-color: #5A9FD6; border-color: #5A9FD6;">
                                <i class="bi bi-eye"></i> Voir
                            </a>
                            <a href="{{ path('app_resultat_editb', {'id': resultat.id}) }}" class="btn btn-warning btn-sm me-1" style="background-color: #FFA559; border-color: #FFA559;">
                                <i class="bi bi-pencil"></i> Modifier
                            </a>
                            <form action="{{ path('app_resultat_deleteb', {'id': resultat.id}) }}" method="post" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce résultat ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ resultat.id) }}">
                                <button type="submit" class="btn btn-danger btn-sm" style="background-color: #E57373; border-color: #E57373;">
                                    <i class="bi bi-trash"></i> Supprimer
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="text-center text-muted">Aucun enregistrement trouvé</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <div class="text-center mt-4">
            <a href="{{ path('app_resultat_newb') }}" class="btn btn-success btn-lg" style="background-color: #81C784; border-color: #81C784;">
                <i class="bi bi-plus-circle"></i> Ajouter un nouveau résultat
            </a>
        </div>
    </div>
{% endblock %}
