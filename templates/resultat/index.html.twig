{% extends 'base.html.twig' %}

{% block title %}Liste des Résultats{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1 class="mb-4 text-center" style="color: #FF8C42; font-weight: 600;">Liste des Résultats</h1> <!-- Titre en orange clair -->

        <table class="table table-striped table-hover table-bordered shadow-sm rounded">
            <thead class="text-center" style="background-color: #4A90E2; color: #FFFFFF;"> <!-- En-tête en bleu clair -->
                <tr>
                    <th scope="col">Note</th>
                    <th scope="col">Date de création</th>
                    <th scope="col">Appréciation</th>
                    <th scope="col" style="width: 200px;">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for resultat in resultats %}
                <tr class="align-middle">
                    <td>{{ resultat.note }}</td>
                    <td class="text-center">{{ resultat.dateCreation ? resultat.dateCreation|date('d/m/Y') : 'N/A' }}</td>
                    <td class="text-center">{{ resultat.appreciation }}</td>
                    <td class="text-center" style="width: 200px;">
                        <div class="d-flex justify-content-center">
                            <a href="{{ path('app_resultat_show', {'id': resultat.id}) }}" class="btn btn-info btn-sm me-1">
                                <i class="bi bi-eye"></i> Voir
                            </a>
                            <a href="{{ path('app_resultat_edit', {'id': resultat.id}) }}" class="btn btn-warning btn-sm me-1">
                                <i class="bi bi-pencil"></i> Modifier
                            </a>
                            <form action="{{ path('app_resultat_delete', {'id': resultat.id}) }}" method="post" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce résultat ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ resultat.id) }}">
                                <button type="submit" class="btn btn-danger btn-sm">
                                    <i class="bi bi-trash"></i> Supprimer
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center text-muted">Aucun enregistrement trouvé</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <div class="text-center mt-4">
            <a href="{{ path('app_resultat_new') }}" class="btn btn-success btn-lg">
                <i class="bi bi-plus-circle"></i> Créer un nouveau résultat
            </a>
        </div>
    </div>
{% endblock %}