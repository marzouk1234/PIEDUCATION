{% extends 'base.html.twig' %}

{% block title %}Modifier le ticket - EDUPLAY{% endblock %}

{% block body %}
    {# Espacement important sous la navbar fixe #}
    <div class="container" style="padding-top: 120px;">

        <h1 class="mb-4 text-primary">Modifier le Ticket</h1>

        {# Carte contenant le formulaire #}
        <div class="card shadow-lg">
            <div class="card-body">
                {{ form_start(form) }}
                
                {# Groupe de champs Nom et Email #}
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        {{ form_label(form.Nom, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.Nom, {'attr': {
                            'class': 'form-control form-control-lg',
                            'placeholder': 'Nom du participant'
                        }}) }}
                    </div>
                    
                    <div class="col-md-6">
                        {{ form_label(form.Email, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.Email, {'attr': {
                            'class': 'form-control',
                            'placeholder': 'email@exemple.com'
                        }}) }}
                    </div>
                </div>

                {# Groupe de champs Prix et Date #}
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        {{ form_label(form.Prix, null, {'label_attr': {'class': 'form-label'}}) }}
                        <div class="input-group">
                            {{ form_widget(form.Prix, {'attr': {
                                'class': 'form-control',
                                'placeholder': '00.00'
                            }}) }}
                            <span class="input-group-text">€</span>
                        </div>
                    </div>
                    
                    <div class="col-md-6">
                        {{ form_label(form.PuchaseDate, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.PuchaseDate, {'attr': {
                            'class': 'form-control flatpickr',
                            'placeholder': 'Date d\'achat'
                        }}) }}
                    </div>
                </div>

                {# Champ Événement #}
                <div class="mb-4">
                    {{ form_label(form.Event, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.Event, {'attr': {
                        'class': 'form-select form-select-lg'
                    }}) }}
                </div>

                {# Boutons d'action #}
                <div class="d-flex justify-content-end gap-2">
                    <a href="{{ path('app_ticket_index') }}" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left"></i> Retour à la liste
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Mettre à jour
                    </button>
                    {{ include('ticket/_delete_form.html.twig') }}
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Ajustements pour la navbar fixe */
        body {
            padding-top: 100px;
        }
        
        .form-label {
            font-weight: 600;
            color: #2c3e50;
        }
        
        .flatpickr-input {
            background: #fff !important;
            cursor: pointer;
        }
        
        .card {
            border-radius: 15px;
        }
        
        .input-group-text {
            background-color: #e9ecef;
            border-color: #ced4da;
        }
        
        .container {
            max-width: 800px;
            margin: 0 auto;
        }
    </style>
{% endblock %}
