{% extends 'base.html.twig' %}

{% block title %}Liste Des Tickets{% endblock %}

{% block body %}
<div class="container pt-5 mt-5">
    <!-- En-tête -->
    <div class="card bg-primary text-white mb-4">
        <div class="card-body py-3">
            <h1 class="h4 mb-0">
                <i class="bi bi-ticket-perforated me-2"></i>
                Liste Des Tickets
            </h1>
        </div>
    </div>

    <!-- Tableau -->
    <div class="card shadow">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Nom</th>
                            <th>Email</th>
                            <th>Prix</th>
                            <th>Date d'achat</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for ticket in tickets %}
                        <tr>
                            <td>{{ ticket.id }}</td>
                            <td>{{ ticket.Nom }}</td>
                            <td>{{ ticket.Email }}</td>
                            <td>{{ ticket.Prix }} €</td>
                            <td>{{ ticket.PuchaseDate|date('d/m/Y H:i') }}</td>
                            <td class="text-end">
                                <div class="d-flex gap-2 justify-content-end">
                                    <a href="{{ path('app_ticket_show', {'id': ticket.id}) }}" 
                                       class="btn btn-sm btn-primary">
                                        <i class="bi bi-eye"></i> Voir
                                    </a>
                                    <a href="{{ path('app_ticket_edit', {'id': ticket.id}) }}" 
                                       class="btn btn-sm btn-warning">
                                        <i class="bi bi-pencil"></i> Modifier
                                    </a>
                                    <form method="post" 
                                          action="{{ path('app_ticket_delete', {'id': ticket.id}) }}">
                                        <input type="hidden" name="_token" 
                                               value="{{ csrf_token('delete' ~ ticket.id) }}">
                                        <button class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i> Supprimer
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">
                                Aucun ticket trouvé
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}