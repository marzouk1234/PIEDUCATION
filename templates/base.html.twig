<!DOCTYPE html>
<html lang="fr"> <!-- Langue changée vers le français -->
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="Plateforme EduPlay - Éducation interactive">
    <meta name="author" content="Votre Nom">
    <link rel="preconnect" href="https://fonts.gstatic.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <title>{% block title %}EduPlay{% endblock %}</title>
    
    <!-- Stylesheets -->
    {% block stylesheets %}
        <!-- Bootstrap CSS + Icons -->
        <link href="{{ asset('assets/vendor/bootstrap/css/bootstrap.min.css') }}" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
        
        <!-- CSS personnalisés -->
        <link rel="stylesheet" href="{{ asset('assets/css/fontawesome.css') }}">
        <link rel="stylesheet" href="{{ asset('assets/css/templatemo-space-dynamic.css') }}">
        <link rel="stylesheet" href="{{ asset('assets/css/animated.css') }}">
        <link rel="stylesheet" href="{{ asset('assets/css/owl.css') }}">
    {% endblock %}
</head>

<body>
    <!-- Préloader -->
    <div id="js-preloader" class="js-preloader">
        <div class="preloader-inner">
            <span class="dot"></span>
            <div class="dots">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </div>
    </div>

    <!-- Barre de navigation -->
    {% block navbar %}
    <header class="header-area header-sticky wow slideInDown" data-wow-duration="0.75s" data-wow-delay="0s">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <nav class="main-nav">
                        <!-- Logo -->
                        <a href="{{ path('app_home') }}" class="logo">
                            <h4>Edu<span>Play</span></h4>
                        </a>
                        
                        <!-- Menu principal -->
                        <ul class="nav">
                            <li class="scroll-to-section"><a href="#about">À propos</a></li>
                            <li class="scroll-to-section"><a href="#services">Cours</a></li>
                            <li class="scroll-to-section"><a href="#portfolio">Forum</a></li>
                            <li class="scroll-to-section"><a href="#blog">Évaluations</a></li>
                            <li class="scroll-to-section"><a href="#contact">Événements</a></li>
                            <li class="scroll-to-section">
                                <div class="main-red-button"><a href="#contact">Contact</a></div>
                            </li>
                        </ul>
                        
                        <!-- Menu mobile -->
                        <a class='menu-trigger'>
                            <span>Menu</span>
                        </a>
                    </nav>
                </div>
            </div>
        </div>
    </header>
    {% endblock %}

    <!-- Contenu principal -->
    {% block body %}{% endblock %}

    <!-- Pied de page -->
    {% block footer %}
    <footer>
        <div class="container">
            <div class="row">
                <div class="col-lg-12 wow fadeIn" data-wow-duration="1s" data-wow-delay="0.25s">
                    <p>© Copyright {{ "now"|date("Y") }} EduPlay. Tous droits réservés.</p>
                </div>
            </div>
        </div>
    </footer>
    {% endblock %}

    <!-- JavaScript -->
    {% block javascripts %}
        <script src="{{ asset('assets/vendor/jquery/jquery.min.js') }}"></script>
        <script src="{{ asset('assets/vendor/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
        <script src="{{ asset('assets/js/owl-carousel.js') }}"></script>
        <script src="{{ asset('assets/js/animation.js') }}"></script>
        <script src="{{ asset('assets/js/imagesloaded.js') }}"></script>
        <script src="{{ asset('assets/js/templatemo-custom.js') }}"></script>
    {% endblock %}
</body>
</html>