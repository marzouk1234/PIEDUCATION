{% extends 'front.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}
{{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate'}}) }}

<style>
    .register-container {
        max-width: 500px;
        margin: 5rem auto;
        padding: 2rem;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        border-radius: 10px;
        box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.2);
    }
    .register-title {
        text-align: center;
        font-size: 2rem;
        font-weight: bold;
        margin-bottom: 1.5rem;
        color: black;
    }
    .form-label {
        font-weight: bold;
    }
    .form-control {
        padding: 10px;
        width: 100%;
        border: 1px solid #ccc;
        border-radius: 5px;
        margin-bottom: 1rem;
    }
    .btn-register {
        background-color:rgb(201, 72, 72);
        color: white;
        padding: 12px;
        width: 100%;
        border: none;
        border-radius: 5px;
        font-size: 1rem;
        cursor: pointer;
        transition: background 0.3s ease;
    }
    .btn-register:hover {
        background-color:rgb(242, 47, 8);
    }
    .signup-link {
        display: block;
        text-align: center;
        margin-top: 1rem;
    }
    .signup-link a {
        color:rgb(27, 38, 113);
        text-decoration: none;
    }
    .signup-link a:hover {
        text-decoration: underline;
    }
</style>

<div class="main-banner" id="top">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="register-container bg-gray-900 text-black p-6">
                    <h1 class="register-title">Create an Account</h1>

                    {{ form_start(registrationForm) }}
                        <div>
                            {{ form_label(registrationForm.nom, 'First Name', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(registrationForm.nom, {'attr': {'class': 'form-control'}}) }}
                            {% if registrationForm.nom.vars.errors is not empty %}
                                <div class="text-danger">
                                    {{ form_errors(registrationForm.nom) }}
                                </div>
                            {% endif %}
                        </div>

                        <div>
                            {{ form_label(registrationForm.prenom, 'Last Name', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(registrationForm.prenom, {'attr': {'class': 'form-control'}}) }}
                            {% if registrationForm.prenom.vars.errors is not empty %}
                                <div class="text-danger">
                                    {{ form_errors(registrationForm.prenom) }}
                                </div>
                            {% endif %}
                        </div>

                        <div>
                            {{ form_label(registrationForm.dateNaissance, 'Date of Birth', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(registrationForm.dateNaissance, {'attr': {'class': 'form-control', 'type': 'date'}}) }}
                            {% if registrationForm.dateNaissance.vars.errors is not empty %}
                                <div class="text-danger">
                                    {{ form_errors(registrationForm.dateNaissance) }}
                                </div>
                            {% endif %}
                        </div>

                        <div>
                            {{ form_label(registrationForm.email, 'Email', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control'}}) }}
                            {% if registrationForm.email.vars.errors is not empty %}
                                <div class="text-danger">
                                    {{ form_errors(registrationForm.email) }}
                                </div>
                            {% endif %}
                        </div>

                        <div>
                            {{ form_label(registrationForm.roles, 'Role', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(registrationForm.roles, {'attr': {'class': 'form-control'}}) }}
                            {% if registrationForm.roles.vars.errors is not empty %}
                                <div class="text-danger">
                                    {{ form_errors(registrationForm.roles) }}
                                </div>
                            {% endif %}
                        </div>

                        <div>
                            {{ form_label(registrationForm.plainPassword, 'Password', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-control'}}) }}
                            {% if registrationForm.plainPassword.vars.errors is not empty %}
                                <div class="text-danger">
                                    {{ form_errors(registrationForm.plainPassword) }}
                                </div>
                            {% endif %}
                        </div>

                        <div>
                            {{ form_widget(registrationForm.agreeTerms) }}
                            <label for="{{ registrationForm.agreeTerms.vars.id }}" class="ml-2">I agree to the terms and conditions</label>
                            {% if registrationForm.agreeTerms.vars.errors is not empty %}
                                <div class="text-danger">
                                    {{ form_errors(registrationForm.agreeTerms) }}
                                </div>
                            {% endif %}
                        </div>

                        <button type="submit" class="btn-register">Register</button>
                    {{ form_end(registrationForm) }}

                    <div class="signup-link">
                        <p>Already have an account? <a href="{{ path('app_login') }}">Sign In</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        // Sélectionne les vrais IDs des champs générés par Symfony
        const nomField = document.getElementById("registration_form_nom");
        const prenomField = document.getElementById("registration_form_prenom");

        if (nomField) {
            nomField.addEventListener("keydown", function (e) {
                if (e.key >= '0' && e.key <= '9') {
                    e.preventDefault();  // Bloquer la saisie de chiffres
                }
            });
        }

        if (prenomField) {
            prenomField.addEventListener("keydown", function (e) {
                if (e.key >= '0' && e.key <= '9') {
                    e.preventDefault();  // Bloquer la saisie de chiffres
                }
            });
        }
    });
</script>


{% endblock %}
