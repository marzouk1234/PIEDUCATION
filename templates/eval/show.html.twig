{% extends 'base2.html.twig' %}

{% block title %}Détails de l'Évaluation{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1 class="mb-4 text-center" style="color: #FF8C42; font-weight: 600;">Détails de l'Évaluation</h1> <!-- Titre en orange clair -->

        <div class="card shadow-sm p-4" style="max-width: 800px; margin: 0 auto; background-color: #F9F9F9; border: 1px solid #E0E0E0;">
            <table class="table table-striped table-hover table-bordered shadow-sm rounded">
                <tbody>
                    <tr>
                        <th scope="row" style="width: 30%;">ID</th>
                        <td>{{ evaluation.id }}</td>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                </tr>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                <tr>
                        <th scope="row">Titre</th>
                        <td>{{ evaluation.titre }}</td>
                    </tr>
                    <tr>
                        <th scope="row">Date</th>
                        <td>{{ evaluation.date ? evaluation.date|date('d/m/Y') : 'N/A' }}</td>
                    </tr>
                    <tr>
                        <th scope="row">Type</th>
                        <td>{{ evaluation.type }}</td>
                    </tr>
                </tbody>
            </table>

            <div class="text-center mt-4">
                <a href="{{ path('app_eval_index') }}" class="btn btn-secondary me-2">
                    <i class="bi bi-arrow-left"></i> Retour à la liste
                </a>
            </div>
        </div>
    </div>
{% endblock %}