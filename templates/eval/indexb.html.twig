{% extends 'back.html.twig' %}

{% block title %}Évaluations (Back-Office){% endblock %}

{% block body %}
    <div class="container mt-4">
    <div >
    </div>
    <div class="container mt-4">
    <div class="d-flex justify-content-end mb-3">
    <a href="{{ path('app_eval_index') }}" class="btn btn-primary">Go to front</a>
</div>
        <h1 class="mb-4 text-center" style="color: #FF8C42; font-weight: 600;">Liste des Évaluations</h1>

        <table class="table table-striped table-hover table-bordered shadow-sm rounded" style="background-color: #F9F9F9; border-color: #E0E0E0;">
            <thead class="text-center" style="background-color: #5A9FD6; color: #FFFFFF;">
                <tr>
                    <th scope="col" class="sortable" data-sort="titre">Titre</th>
                    <th scope="col" class="sortable" data-sort="date">Date</th>
                    <th scope="col" class="sortable" data-sort="type">Type</th>
                    <th scope="col" style="width: 200px;">Actions</th>
                </tr>
            </thead>
            <tbody id="evaluation-table-body">
            {% for evaluation in evaluations %}
                <tr class="align-middle">
                    <td class="text-center">{{ evaluation.titre }}</td>
                    <td class="text-center">{{ evaluation.date ? evaluation.date|date('d/m/Y') : 'N/A' }}</td>
                    <td class="text-center">{{ evaluation.type }}</td>
                    <td class="text-center" style="width: 200px;">
                        <div class="d-flex justify-content-center">
                            <a href="{{ path('app_eval_showb', {'id': evaluation.id}) }}" class="btn btn-info btn-sm me-1" style="background-color: #5A9FD6; border-color: #5A9FD6;">
                                <i class="bi bi-eye"></i> Voir
                            </a>
                            <a href="{{ path('app_eval_editb', {'id': evaluation.id}) }}" class="btn btn-warning btn-sm me-1" style="background-color: #FFA559; border-color: #FFA559;">
                                <i class="bi bi-pencil"></i> Modifier
                            </a>
                            <form action="{{ path('app_eval_deleteb', {'id': evaluation.id}) }}" method="post" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette évaluation ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ evaluation.id) }}">
                                <button type="submit" class="btn btn-danger btn-sm" style="background-color: #E57373; border-color: #E57373;">
                                    <i class="bi bi-trash"></i> Supprimer
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center text-muted">Aucun enregistrement trouvé</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <div class="d-flex justify-content-center mt-4">
            {{ knp_pagination_render(evaluations) }}
        </div>

        <div class="text-center mt-4">
            <a href="{{ path('app_eval_newb') }}" class="btn btn-success btn-lg" style="background-color: #81C784; border-color: #81C784;">
                <i class="bi bi-plus-circle"></i> Ajouter une nouvelle évaluation
            </a>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Variables pour la gestion du tri
            let sortOrder = { 'titre': true, 'date': true, 'type': true }; // true = ascendant, false = descendant

            // Fonction de tri
            function sortTable(column, isAscending) {
                const table = document.querySelector('table');
                const rows = Array.from(table.querySelectorAll('tbody tr'));
                const index = {
                    'titre': 0,
                    'date': 1,
                    'type': 2
                }[column];

                rows.sort((rowA, rowB) => {
                    const cellA = rowA.children[index].innerText.trim();
                    const cellB = rowB.children[index].innerText.trim();

                    let comparison = 0;
                    if (column === 'date') {
                        // Convertir les dates au format 'd/m/Y' en objets Date
                        const dateA = parseDate(cellA);
                        const dateB = parseDate(cellB);
                        comparison = dateA - dateB;
                    } else {
                        // Comparaison de texte pour les autres colonnes
                        comparison = cellA.localeCompare(cellB, 'fr', { sensitivity: 'base' });
                    }

                    return isAscending ? comparison : -comparison;
                });

                rows.forEach(row => table.querySelector('tbody').appendChild(row));
            }

            // Fonction pour convertir une chaîne de date 'd/m/Y' en objet Date
            function parseDate(dateStr) {
                if (dateStr === 'N/A') return new Date(0); // Gérer les dates non disponibles
                const [day, month, year] = dateStr.split('/');
                return new Date(year, month - 1, day);
            }

            // Ajouter les événements de tri sur les en-têtes de colonnes
            document.querySelectorAll('.sortable').forEach(header => {
                header.addEventListener('click', () => {
                    const column = header.dataset.sort;
                    const isAscending = sortOrder[column];

                    // Trier la table
                    sortTable(column, isAscending);

                    // Inverser l'ordre de tri pour la prochaine fois
                    sortOrder[column] = !isAscending;

                    // Mettre à jour l'indication visuelle du tri
                    document.querySelectorAll('.sortable').forEach(th => th.classList.remove('asc', 'desc'));
                    header.classList.add(isAscending ? 'asc' : 'desc');
                });
            });
        });
    </script>
{% endblock %}