{{ form_start(form, {'attr': {'id': 'evaluationForm', 'class': 'form-horizontal'}}) }}

    <div class="mb-3">
        {{ form_label(form.titre, 'Titre', {'label_attr': {'class': 'form-label fw-bold text-primary'}}) }}
        {{ form_widget(form.titre, {'attr': {'class': 'form-control border-primary', 'placeholder': 'Entrez le titre'}}) }}
        <small class="form-text text-muted">Le titre doit contenir au moins 3 caractères et commencer par une lettre.</small>
        <div class="invalid-feedback">Le titre doit commencer par une lettre et ne peut pas être composé uniquement de chiffres.</div>
    </div>

    <div class="mb-3">
        {{ form_label(form.date, 'Date', {'label_attr': {'class': 'form-label fw-bold text-primary'}}) }}
        {{ form_widget(form.date, {'attr': {'class': 'form-control border-primary'}}) }}
        <div class="invalid-feedback">La date est obligatoire.</div>
    </div>

    <div class="mb-3">
        {{ form_label(form.type, 'Type', {'label_attr': {'class': 'form-label fw-bold text-primary'}}) }}
        {{ form_widget(form.type, {'attr': {'class': 'form-control border-primary'}}) }}
        <div class="invalid-feedback">Le type est obligatoire.</div>
    </div>

    <div class="text-center">
        <button type="submit" class="btn btn-primary" style="background-color: #4A90E2; border-color: #4A90E2;">
            <i class="bi bi-save"></i> {{ button_label|default('Enregistrer') }}
        </button>
    </div>

{{ form_end(form) }}

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>

<script>
$(document).ready(function() {
    $("#evaluationForm").validate({
        rules: {
            'evaluation[titre]': {
                required: true,
                minlength: 3,
                regex: /^[a-zA-ZÀ-ÿ][a-zA-ZÀ-ÿ0-9\s\-'!?,.]*$/
            },
            'evaluation[date]': {
                required: true,
                date: true
            },
            'evaluation[type]': {
                required: true
            }
        },
        messages: {
            'evaluation[titre]': {
                required: "Le titre est obligatoire.",
                minlength: "Le titre doit contenir au moins 3 caractères.",
                regex: "Le titre doit commencer par une lettre et ne peut pas être composé uniquement de chiffres."
            },
            'evaluation[date]': {
                required: "La date est obligatoire.",
                date: "La date doit être valide."
            },
            'evaluation[type]': {
                required: "Le type est obligatoire."
            }
        },
        errorClass: "is-invalid",
        validClass: "is-valid",
        errorPlacement: function(error, element) {
            error.addClass('invalid-feedback');
            element.closest('.mb-3').append(error);
        },
        highlight: function(element, errorClass, validClass) {
            $(element).addClass(errorClass).removeClass(validClass);
            $(element).closest('.mb-3').find('.form-text').hide();
        },
        unhighlight: function(element, errorClass, validClass) {
            $(element).removeClass(errorClass).addClass(validClass);
            $(element).closest('.mb-3').find('.form-text').show();
        },
        onfocusout: function(element) {
            this.element(element);
        }
    });

    $.validator.addMethod("regex", function(value, element, regexp) {
        var re = new RegExp(regexp);
        return this.optional(element) || re.test(value);
    }, "Veuillez vérifier votre saisie.");
});
</script>
