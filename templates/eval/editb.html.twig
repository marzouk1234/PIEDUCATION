{% extends 'back.html.twig' %}

{% block title %}Modifier l'Évaluation{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1 class="mb-4 text-center" style="color: #FF8C42; font-weight: 600;">Modifier l'Évaluation</h1> <!-- Titre en orange clair -->

        <div class="card shadow-sm p-4" style="max-width: 800px; margin: 0 auto; background-color: #F9F9F9; border: 1px solid #E0E0E0;">
            {{ include('eval/_formb.html.twig', {'button_label': 'Mettre à jour'}) }}

            <div class="text-center mt-4">
                <a href="{{ path('app_eval_indexb') }}" class="btn btn-secondary me-2">
                    <i class="bi bi-arrow-left"></i> Retour à la liste
                </a>
                <form action="{{ path('app_eval_deleteb', {'id': evaluation.id}) }}" method="post" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette évaluation ?');" style="display: inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ evaluation.id) }}">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Supprimer
                    </button>
                </form>
            </div>
        </div>
    </div>
{% endblock %}