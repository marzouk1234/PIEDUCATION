{% extends 'base2.html.twig' %}

{% block title %}Evaluation index{% endblock %}

{% block body %}
<div >
    </div>
    <div class="container mt-4">
    <div class="d-flex justify-content-end mb-3">
    <a href="{{ path('app_eval_indexb') }}" class="btn btn-primary">Go to Back</a>
</div>
        <h1 class="mb-4 text-center" style="color: #FF8C42; font-weight: 600;">Liste des Évaluations</h1> <!-- Titre en orange clair -->

        <table class="table table-striped table-hover table-bordered shadow-sm rounded" style="background-color: #F9F9F9; border-color: #E0E0E0;">
            <thead class="text-center" style="background-color: #4A90E2; color: #FFFFFF;"> <!-- En-tête en bleu clair -->
                <tr>
                    <th scope="col">Titre</th>
                    <th scope="col">Date</th>
                    <th scope="col">Type</th>
                                        <th scope="col">action</th>
                </tr>
            </thead>
            <tbody>
            {% for evaluation in evaluations %}
                <tr class="align-middle">
                    <td>{{ evaluation.titre }}</td>
                    <td class="text-center">{{ evaluation.date ? evaluation.date|date('d/m/Y') : 'N/A' }}</td>
                    <td class="text-center">{{ evaluation.type }}</td>
                    <td class="text-center" style="width: 200px;">
                        <div class="d-flex justify-content-center">
                            <a href="{{ path('app_eval_show', {'id': evaluation.id}) }}" class="btn btn-info btn-sm me-1" style="background-color: #4A90E2; border-color: #4A90E2;">
                                <i class="bi bi-eye"></i> Voir
                            </a>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center text-muted">Aucun enregistrement trouvé</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

    </div>
{% endblock %}