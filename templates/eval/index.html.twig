    </div>

    <!-- Script JavaScript pour gérer la recherche -->
    <script>
     document.addEventListener('DOMContentLoaded', function () {
        let searchTimeout;
        const searchInput = document.getElementById('search');
        const searchBtn = document.getElementById('searchBtn');
        const resultsContainer = document.getElementById('searchResults');

        function performSearch() {
            clearTimeout(searchTimeout);
            const searchTerm = searchInput.value.trim();

            if (searchTerm.length >= 2) {
                fetch(`/eval/search-evaluation?q=${encodeURIComponent(searchTerm)}`, {
                    method: 'GET', // S'assurer que la méthode GET est utilisée
                    headers: {
                        'Content-Type': 'application/json', // Optionnel, mais utile si tu attends des JSON
                    }
                })
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Erreur réseau');
                        }
                        return response.json();
                    })
                    .then(data => {
                        resultsContainer.innerHTML = ''; // Efface les résultats précédents

                        if (data.length > 0) {
                            data.forEach(evaluation => {
                                const li = document.createElement('li');
                                li.className = 'list-group-item';
                                li.innerHTML = `<a href="/eval/${evaluation.id}" class="text-decoration-none">${evaluation.titre}</a>`;
                                resultsContainer.appendChild(li);
                            });
                            resultsContainer.style.display = 'block';
                        } else {
                            resultsContainer.innerHTML = '<li class="list-group-item text-muted">Aucun résultat trouvé</li>';
                            resultsContainer.style.display = 'block';
                        }
                    })
                    .catch(error => {
                        console.error('Erreur lors de la recherche :', error);
                        resultsContainer.innerHTML = '<li class="list-group-item text-danger">Erreur lors de la recherche. Veuillez réessayer plus tard.</li>';
                        resultsContainer.style.display = 'block';
                    });
            } else {
                resultsContainer.innerHTML = ''; // Efface les résultats si le terme est trop court
                resultsContainer.style.display = 'none';
            }
        }

        // Déclenchement automatique à la saisie
        searchInput.addEventListener('input', function () {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(performSearch, 300);
        });

        // Déclenchement manuel avec le bouton
        searchBtn.addEventListener('click', performSearch);
    });
    </script>

{% endblock %}
