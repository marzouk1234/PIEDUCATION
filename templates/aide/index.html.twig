{% extends 'base.html.twig' %}

{% block title %}Liste des Aides{% endblock %}

{% block stylesheets %}
<style>
    body {
        background-color: #f8f9fa;
    }

    .container {
        max-width: 1200px;
        margin: auto;
        padding: 20px;
    }

    h1 {
        text-align: center;
        margin-bottom: 30px;
        font-weight: bold;
        color: #333;
    }

    /* Formulaire de recherche */
    .search-form {
        background: white;
        padding: 20px;
        border-radius: 8px;
        box-shadow: 0px 2px 10px rgba(0, 0, 0, 0.1);
        margin-bottom: 30px;
    }

    .form-control, .form-select {
        height: 45px;
    }

    .btn-search {
        background: #17a2b8;
        color: white;
        width: 100%;
        font-size: 16px;
        padding: 10px;
        transition: background 0.3s, transform 0.2s;
    }

    .btn-search:hover {
        background: #117a8b;
        transform: scale(1.05);
    }

    /* Tableau */
    .table-container {
        overflow-x: auto;
    }

    .table {
        background: white;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0px 2px 10px rgba(0, 0, 0, 0.1);
    }

    .table th, .table td {
        padding: 15px;
        text-align: center;
        white-space: nowrap;
    }

    .table thead {
        background: #007bff;
        color: white;
    }

    .table tbody tr:nth-child(odd) {
        background: #f2f2f2;
    }

    /* Boutons */
    .btn-animated {
        display: inline-block;
        padding: 10px 15px;
        border-radius: 5px;
        font-weight: bold;
        text-decoration: none;
        transition: all 0.3s ease-in-out;
        font-size: 14px;
    }

    .btn-show {
        background: #007bff;
        color: white;
    }

    .btn-show:hover {
        background: #0056b3;
        transform: scale(1.1);
    }

    .btn-edit {
        background: #ffc107;
        color: white;
    }

    .btn-edit:hover {
        background: #d39e00;
        transform: scale(1.1);
    }

    .btn-create {
        background: #28a745;
        color: white;
        display: block;
        width: 200px;
        text-align: center;
        padding: 12px;
        border-radius: 5px;
        font-weight: bold;
        margin: 30px auto 0;
        font-size: 16px;
    }

    .btn-create:hover {
        background: #1e7e34;
        transform: scale(1.1);
    }

    /* Styles du Chatbot */
    .chatbot-container {
        margin-top: 50px;
        padding: 20px;
        background: white;
        border-radius: 8px;
        box-shadow: 0px 2px 10px rgba(0, 0, 0, 0.1);
        display: none; /* Masqué par défaut */
    }

    .chatbox {
        width: 100%;
        max-width: 400px;
        margin: auto;
        background: white;
        padding: 10px;
        border-radius: 10px;
        box-shadow: 0px 0px 10px gray;
    }

    .chat {
        text-align: left;
        max-height: 400px;
        overflow-y: auto;
        padding: 10px;
        border-bottom: 1px solid #ccc;
    }

    .input-area {
        display: flex;
        margin-top: 10px;
    }

    .input-area input {
        flex: 1;
        padding: 10px;
        border: 1px solid #ccc;
        border-radius: 5px;
    }

    .input-area button {
        padding: 10px;
        border: none;
        background: #007bff;
        color: white;
        border-radius: 5px;
        cursor: pointer;
        margin-left: 10px;
    }

    .input-area button:hover {
        background: #0056b3;
    }

    .message {
        margin: 5px 0;
        padding: 8px;
        border-radius: 5px;
    }

    .user {
        background: #d1e7ff;
        text-align: right;
    }

    .bot {
        background: #e6e6e6;
        text-align: left;
    }

    /* Bouton pour afficher/masquer le chatbot */
    .chatbot-toggle {
        position: fixed;
        bottom: 20px;
        right: 20px;
        background: #007bff;
        color: white;
        border: none;
        border-radius: 50%;
        width: 60px;
        height: 60px;
        font-size: 24px;
        cursor: pointer;
        box-shadow: 0px 2px 10px rgba(0, 0, 0, 0.1);
        transition: background 0.3s, transform 0.2s;
    }

    .chatbot-toggle:hover {
        background: #0056b3;
        transform: scale(1.1);
    }
</style>
{% endblock %}

{% block body %}
<div class="container">
    <h1>Liste des Aides</h1>

    <!-- Formulaire de recherche -->
    <form method="GET" action="{{ path('app_aide_index') }}" class="search-form">
        <div class="row">
            <div class="col-md-5">
                <input type="text" name="q" value="{{ query }}" placeholder="Rechercher..." class="form-control">
            </div>
            <div class="col-md-4">
                <select name="sort" class="form-select">
                    <option value="date_creation" {% if sort == 'date_creation' %}selected{% endif %}>Date</option>
                    <option value="sujet" {% if sort == 'sujet' %}selected{% endif %}>Sujet</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-search"><i class="fas fa-search"></i> Rechercher</button>
            </div>
        </div>
    </form>

    <!-- Tableau des aides -->
    <div class="table-container">
        <table class="table">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Sujet du Formulaire</th> 
                    <th>Sujet</th>
                    <th>Description</th>
                    <th>Date de Création</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for aide in aides %}
                <tr>
                    <td>{{ aide.id }}</td>
                    <td>{{ aide.form is not null and aide.form.sujet is not null ? aide.form.sujet : 'Aucun sujet' }}</td>
                    <td>{{ aide.sujet }}</td>
                    <td>{{ aide.description }}</td>
                    <td>{{ aide.dateCreation ? aide.dateCreation|date('Y-m-d H:i:s') : '' }}</td>
                    <td>
                        <a href="{{ path('app_aide_show', {'id': aide.id}) }}" class="btn-animated btn-show">
                            <i class="fas fa-eye"></i> Voir
                        </a>
                        <a href="{{ path('app_aide_edit', {'id': aide.id}) }}" class="btn-animated btn-edit">
                            <i class="fas fa-edit"></i> Modifier
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6">Aucun enregistrement trouvé</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    {% if aides is defined and aides|length > 0 %}
        <div class="d-flex justify-content-center">
            {{ knp_pagination_render(aides) }}
        </div>
    {% endif %}

    <!-- Bouton pour créer une nouvelle aide -->
    <a href="{{ path('app_aide_new') }}" class="btn-create">
        <i class="fas fa-plus"></i> Créer Nouveau
    </a>

    <!-- Section du Chatbot -->
    <div class="chatbot-container" id="chatbotContainer">
        <h2>🎨 Art Chatbot</h2>
        <div class="chatbox">
            <div class="chat" id="chat"></div>
            <div class="input-area">
                <input type="text" id="userInput" placeholder="Ask about art..." />
                <button onclick="sendMessage()">Send</button>
            </div>
        </div>
    </div>
</div>

<!-- Bouton pour afficher/masquer le chatbot -->
<button class="chatbot-toggle" onclick="toggleChatbot()">💬</button>

<!-- Script du Chatbot -->
<script>
    // Fonction pour afficher/masquer le chatbot
    function toggleChatbot() {
        const chatbotContainer = document.getElementById("chatbotContainer");
        if (chatbotContainer.style.display === "none" || chatbotContainer.style.display === "") {
            chatbotContainer.style.display = "block";
        } else {
            chatbotContainer.style.display = "none";
        }
    }

    // Fonction pour envoyer un message
    async function sendMessage() {
        let userInput = document.getElementById("userInput").value.trim();
        if (!userInput) return;

        appendMessage("You", userInput, "user");
        document.getElementById("userInput").value = "";

        try {
            let response = await fetch("/chat", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ message: userInput })
            });

            let data = await response.json();
            appendMessage("Bot", data.reply, "bot");
        } catch (error) {
            appendMessage("Bot", "Error connecting to the server.", "bot");
        }
    }

    // Fonction pour ajouter un message à la discussion
    function appendMessage(sender, message, type) {
        let chat = document.getElementById("chat");
        let messageElement = document.createElement("div");
        messageElement.classList.add("message", type);
        messageElement.innerHTML = `<strong>${sender}:</strong> ${message}`;
        chat.appendChild(messageElement);
        chat.scrollTop = chat.scrollHeight;
    }
</script>
{% endblock %}