{% extends 'base.html.twig' %}

{% block title %}Aide index{% endblock %}

{% block stylesheets %}
<style>
    /* Espacement général */
    body {
        background-color: #f8f9fa;
    }

    .container {
        max-width: 1200px;
        margin: auto;
        padding: 20px;
    }

    h1 {
        text-align: center;
        margin-bottom: 30px;
        font-weight: bold;
        color: #333;
    }

    /* Formulaire de recherche */
    form {
        background: white;
        padding: 20px;
        border-radius: 8px;
        box-shadow: 0px 2px 10px rgba(0, 0, 0, 0.1);
        margin-bottom: 30px;
    }

    .form-control, .form-select {
        height: 45px;
    }

    .btn-search {
        background: #17a2b8;
        color: white;
        transition: background 0.3s, transform 0.2s;
        width: 100%;
        font-size: 16px;
        padding: 10px;
    }

    .btn-search:hover {
        background: #117a8b;
        transform: scale(1.05);
    }

    /* Tableau */
    .table {
        background: white;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0px 2px 10px rgba(0, 0, 0, 0.1);
    }

    .table th, .table td {
        padding: 15px;
        text-align: center;
    }

    .table thead {
        background: #007bff;
        color: white;
    }

    .table tbody tr:nth-child(odd) {
        background: #f2f2f2;
    }

    /* Boutons */
    .btn-animated {
        display: inline-block;
        padding: 10px 20px;
        border-radius: 5px;
        font-weight: bold;
        text-decoration: none;
        transition: all 0.3s ease-in-out;
        font-size: 14px;
    }

    .btn-show {
        background: #007bff;
        color: white;
    }

    .btn-show:hover {
        background: #0056b3;
        transform: scale(1.1);
    }

    .btn-edit {
        background: #ffc107;
        color: white;
    }

    .btn-edit:hover {
        background: #d39e00;
        transform: scale(1.1);
    }

    .btn-create {
        background: #28a745;
        color: white;
        display: block;
        width: 200px;
        text-align: center;
        padding: 12px;
        border-radius: 5px;
        font-weight: bold;
        margin: 30px auto 0;
        font-size: 16px;
    }

    .btn-create:hover {
        background: #1e7e34;
        transform: scale(1.1);
    }

</style>
{% endblock %}

{% block body %}
<div class="container">
    <h1>Aide index</h1>

    <!-- Formulaire de recherche -->
    <form method="GET" action="{{ path('app_aide_index') }}" class="mb-3">
        <div class="row">
            <div class="col-md-5">
                <input type="text" name="q" value="{{ query }}" placeholder="Rechercher..." class="form-control">
            </div>
            <div class="col-md-4">
                <select name="sort" class="form-select">
                    <option value="date_creation" {% if sort == 'date_creation' %}selected{% endif %}>Date</option>
                    <option value="sujet" {% if sort == 'sujet' %}selected{% endif %}>Sujet</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-search">Rechercher</button>
            </div>
        </div>
    </form>

    <!-- Tableau des aides -->
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Sujet du Formulaire</th> 
                <th>Sujet</th>
                <th>Description</th>
                <th>Date de Création</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for aide in aides %}
            <tr>
                <td>{{ aide.id }}</td>
                <td>{{ aide.form is not null and aide.form.sujet is not null ? aide.form.sujet : 'Aucun sujet' }}</td>
                <td>{{ aide.sujet }}</td>
                <td>{{ aide.description }}</td>
                <td>{{ aide.dateCreation ? aide.dateCreation|date('Y-m-d H:i:s') : '' }}</td>
                <td>
                    <a href="{{ path('app_aide_show', {'id': aide.id}) }}" class="btn-animated btn-show">Voir</a>
                    <a href="{{ path('app_aide_edit', {'id': aide.id}) }}" class="btn-animated btn-edit">Modifier</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">Aucun enregistrement trouvé</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <!-- Bouton pour créer une nouvelle aide -->
    <a href="{{ path('app_aide_new') }}" class="btn-create">Créer Nouveau</a>
</div>
{% endblock %}
