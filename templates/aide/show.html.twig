{% extends 'bac_web.html.twig' %}

{% block title %}Aide{% endblock %}

{% block body %}
    <h1>Aide</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ aide.id }}</td>
            </tr>
            <tr>
                <th>Sujet</th>
                <td>{{ aide.sujet }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ aide.description }}</td>
            </tr>
            <tr>
                <th>Date_creation</th>
                <td>{{ aide.dateCreation ? aide.dateCreation|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_aide_index') }}">back to list</a>

    <a href="{{ path('app_aide_edit', {'id': aide.id}) }}">edit</a>

    {{ include('aide/_delete_form.html.twig') }}
{% endblock %}
