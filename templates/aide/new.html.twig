{% extends 'base15.html.twig' %}

{% block title %}Créer une Aide{% endblock %}

{% block body %}

<!-- ***** Hero Section Start ***** -->
<div class="main-banner wow fadeIn" id="top" data-wow-duration="1s" data-wow-delay="0.5s">
  <div class="container">
    <div class="row">
      <div class="col-lg-12 text-center">
        <h1 class="text-white">Créer une Aide</h1>
        <p class="text-light">Remplissez le formulaire ci-dessous</p>
      </div>
    </div>
  </div>
</div>
<!-- ***** Hero Section End ***** -->

<!-- ***** Formulaire Section Start ***** -->
<section class="contact-us section">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="card shadow-lg border-0 rounded-4 p-4">
          
          <!-- Titre amélioré -->
          <h2 class="text-center text-primary mb-4">
            <i class="fas fa-life-ring"></i> Créer une Aide
          </h2>

          <!-- Gestion des erreurs globales -->
          {% if form.vars.errors|length > 0 %}
            <div class="alert alert-danger">
              <h6><i class="fas fa-exclamation-circle"></i> Erreurs détectées :</h6>
              <ul>
                {% for error in form.vars.errors %}
                  <li>{{ error.message }}</li>
                {% endfor %}
              </ul>
            </div>
          {% endif %}

          {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

          <!-- Champ Sujet -->
          <div class="mb-3">
            <label class="form-label fw-bold">Sujet</label>
            <div class="input-group">
              <span class="input-group-text bg-light"><i class="fas fa-heading"></i></span>
              {{ form_widget(form.sujet, {'attr': {'class': 'form-control', 'placeholder': 'Entrez le sujet...'}}) }}
            </div>
            {% for error in form.sujet.vars.errors %}
              <div class="text-danger mt-1">{{ error.message }}</div>
            {% endfor %}
          </div>

          <!-- Champ Description -->
          <div class="mb-3">
            <label class="form-label fw-bold">Description</label>
            {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': '5', 'placeholder': 'Écrivez la description ici...'}}) }}
            {% for error in form.description.vars.errors %}
              <div class="text-danger mt-1">{{ error.message }}</div>
            {% endfor %}
          </div>

          <!-- Champ Date de création -->
          <div class="mb-3">
            <label class="form-label fw-bold">Date de création</label>
            <div class="input-group">
              <span class="input-group-text bg-light"><i class="fas fa-calendar-alt"></i></span>
              {{ form_widget(form.date_creation, {'attr': {'class': 'form-control'}}) }}
            </div>
            {% for error in form.date_creation.vars.errors %}
              <div class="text-danger mt-1">{{ error.message }}</div>
            {% endfor %}
          </div>

          <!-- Champ Formulaire associé -->
          <div class="mb-3">
            <label class="form-label fw-bold">Formulaire associé</label>
            <div class="input-group">
              <span class="input-group-text bg-light"><i class="fas fa-file-alt"></i></span>
              {{ form_widget(form.form, {'attr': {'class': 'form-select'}}) }}
            </div>
            {% for error in form.form.vars.errors %}
              <div class="text-danger mt-1">{{ error.message }}</div>
            {% endfor %}
          </div>

          <!-- Boutons d'action -->
          <div class="d-flex justify-content-between mt-4">
            <a href="{{ path('app_aide_index') }}" class="btn btn-secondary">
              <i class="fas fa-arrow-left"></i> Retour
            </a>
            <button type="submit" class="btn btn-success">
              <i class="fas fa-check-circle"></i> Enregistrer
            </button>
          </div>

          {{ form_end(form) }}
        </div>
      </div>
    </div>
  </div>
</section>
<!-- ***** Formulaire Section End ***** -->

{% endblock %}
