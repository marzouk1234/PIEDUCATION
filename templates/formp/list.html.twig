{% extends 'bac_web.html.twig' %}

{% block title %}Liste des Formulaires{% endblock %}

{% block body %}

<!-- ***** Hero Section Start ***** -->
<div class="main-banner wow fadeIn" id="top" data-wow-duration="1s" data-wow-delay="0.5s">
  <div class="container text-center">
    <h1 class="text-white">Liste des Formulaires</h1>
    <p class="text-light">Gérez vos formulaires facilement</p>
  </div>
</div>
<!-- ***** Hero Section End ***** -->

<!-- Formulaire de recherche -->
<div class="container mt-4">
  {{ form_start(searchForm, {'attr': {'class': 'row g-3 align-items-center'}}) }}
    <div class="col-md-3">{{ form_row(searchForm.sujet) }}</div>
    <div class="col-md-3">{{ form_row(searchForm.contenu) }}</div>
    <div class="col-md-3">{{ form_row(searchForm.auteur) }}</div>
    <div class="col-md-3">{{ form_row(searchForm.datePub) }}</div>
    <div class="col-12 text-center">
      <button type="submit" class="btn btn-primary">
        <i class="fas fa-search"></i> Rechercher
      </button>
    </div>
  {{ form_end(searchForm) }}
</div>

<!-- Section principale -->
<section class="contact-us section mt-5">
  <div class="container">
    {% if pagination.items is defined and pagination.items is not empty %}
      <div class="row">
        {% for i in pagination.items %}
          {% set hasError = i.sujet is empty or i.auteur is empty or i.contenu is empty %}
          <div class="col-md-4 mb-4">
            <div class="card h-100 {% if hasError %}border-danger{% endif %}">
              <div class="card-body">
                <h5 class="card-title fw-bold">{{ i.sujet }}</h5>
                <h6 class="card-subtitle mb-2 text-muted">Auteur : {{ i.auteur }}</h6>
                <p class="card-text"><small class="text-muted">Date : {{ i.getDatePub()|date('d/m/Y') }}</small></p>
                <p class="card-text">{{ i.contenu|slice(0, 100) ~ '...' }}</p>
                <div class="d-flex justify-content-between align-items-center">
                  <div>
                    <a href="{{ path('app_formp_edit', {id: i.id}) }}" class="btn btn-sm btn-warning">
                      <i class="fas fa-edit"></i> Modifier
                    </a>
                    <a href="{{ path('app_formp_remove', {id: i.id}) }}" 
                       class="btn btn-sm btn-danger"
                       onclick="return confirm('Voulez-vous vraiment supprimer ce formulaire ?');">
                      <i class="fas fa-trash-alt"></i> Supprimer
                    </a>
                  </div>
                  <button class="btn btn-sm btn-success toggle-qr" data-id="{{ i.id }}">
                    <i class="fas fa-qrcode"></i> QR Code
                  </button>
                </div>
                <div id="qrcode-{{ i.id }}" class="qr-code-container mt-2 text-center">
                  <img src="{{ path('form_qrcode', {'id': i.id}) }}" alt="QR Code" class="img-fluid">
                </div>
              </div>
              {% if hasError %}
                <div class="card-footer bg-danger text-white">
                  <strong>Erreur :</strong> Veuillez vérifier les champs du formulaire.
                </div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>

      <!-- Pagination -->
      <div class="d-flex justify-content-center mt-4">
        {{ knp_pagination_render(pagination) }}
      </div>
    {% else %}
      <div class="alert alert-info text-center">
        <i class="fas fa-info-circle"></i> Aucun formulaire disponible.
      </div>
    {% endif %}
  </div>
</section>

<!-- Bouton Ajouter -->
<div class="container text-end mt-4">
  <a href="{{ path('app_formp_new') }}" class="btn btn-lg btn-primary">
    <i class="fas fa-plus-circle"></i> Ajouter un Formulaire
  </a>
</div>

<!-- CSS amélioré -->
<style>
  .btn {
    font-weight: bold;
    transition: 0.3s;
  }

  .btn-warning:hover, .btn-danger:hover, .btn-success:hover {
    transform: scale(1.05);
  }

  /* QR Code Style */
  .qr-code-container {
    display: none;
    text-align: center;
    transition: all 0.3s ease-in-out;
  }

  /* Pagination */
  .pagination {
    display: flex;
    justify-content: center;
    padding: 10px;
  }

  .pagination a {
    padding: 8px 12px;
    margin: 2px;
    border-radius: 5px;
    text-decoration: none;
    font-weight: bold;
    background-color: #007bff;
    color: white;
  }

  .pagination a:hover {
    background-color: #0056b3;
  }

  .pagination .current {
    background-color: #6c757d;
    color: white;
  }

  /* Card Hover Effect */
  .card {
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .card:hover {
    transform: translateY(-5px);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
  }
</style>

<!-- Script JavaScript pour QR Code -->
<script>
  document.addEventListener("DOMContentLoaded", function() {
    document.querySelectorAll(".toggle-qr").forEach(button => {
      button.addEventListener("click", function() {
        let id = this.getAttribute("data-id");
        let qrCodeDiv = document.getElementById("qrcode-" + id);
        qrCodeDiv.style.display = qrCodeDiv.style.display === "none" || qrCodeDiv.style.display === "" ? "block" : "none";
      });
    });
  });
</script>

{% endblock %}