{% extends 'back1.html.twig' %}

{% block title %}Dashbord{% endblock %}

{% block body %}
    <h1>Game index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Prenom</th>
                <th>Type</th>
                <th>Date</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for game in games %}
            <tr>
                <td>{{ game.id }}</td>
                <td>{{ game.nom }}</td>
                <td>{{ game.prenom }}</td>
                <td>{{ game.type }}</td>
                <td>{{ game.date ? game.date|date('Y-m-d') : '' }}</td>
                <td>
                    <a href="{{ path('app_game_edit', {'id': game.id}) }}">edit</a>

                    {{ include('game/_delete_form.html.twig') }}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_game_new') }}">Create new</a>
{% endblock %}
