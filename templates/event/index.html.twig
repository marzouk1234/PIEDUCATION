{% extends 'base.html.twig' %}

{% block title %}Liste Des Événements{% endblock %}

{% block body %}
<div class="container pt-5 mt-5"> {# Correction : remplacer commentaire HTML par Twig #}

    <!-- En-tête -->
    <div class="card bg-primary text-white mb-4">
        <div class="card-body py-3">
            <h1 class="h4 mb-0">
                <i class="bi bi-calendar-event me-2"></i>
                Liste Des Événements
            </h1>
        </div>
    </div>

    <!-- Tableau -->
    <div class="card shadow">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Nom</th>
                            <th>Date</th>
                            <th>Description</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for event in events %}
                        <tr>
                            <td>{{ event.Nom }}</td>
                            <td>{{ event.Date|date('d/m/Y H:i') }}</td>
                            <td>{{ event.Description }}</td>
                            <td class="text-end">
                                <div class="d-flex gap-2 justify-content-end">
                                    <a href="{{ path('app_event_show', {'id': event.id}) }}" 
                                       class="btn btn-sm btn-primary">
                                        <i class="bi bi-eye me-2"></i>Voir
                                    </a>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center py-4 text-muted"> {# Correction : 5 → 4 #}
                                Aucun événement trouvé
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="mt-4 text-center small text-muted">
        <hr>
        © Copyright {{ "now"|date("Y") }} EduPlay Co. Tous droits réservés.
    </footer>
</div>
{% endblock %}