{% extends 'backk.html.twig' %}

{% block title %}Ajouter un Cours{% endblock %}

{% block body %}
    <h1>Ajouter un Cours</h1>

    {% if app.flashes('error') %}
        <div class="alert alert-danger">
            {{ app.flashes('error')|first }}
        </div>
    {% endif %}

    {{ form_start(form) }}  {# Début du formulaire #}
        {{ form_widget(form) }} {# Génère tous les champs #}
        <button type="submit" class="btn btn-primary">Enregistrer</button>
    {{ form_end(form) }} {# Fin du formulaire #}

    <a href="{{ path('cours_indexb') }}" class="btn btn-secondary mt-3">Retour</a>
{% endblock %}