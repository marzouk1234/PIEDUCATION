{% extends 'base1.html.twig' %}

{% block header %}
    <h1>Ajouter un Feedback</h1>

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">
            {{ message }}
        </div>
    {% endfor %}

    {{ form_start(form) }}
        <div class="form-group mb-3">
            {{ form_label(form.id_jeux, 'ID du Jeu') }}
            {{ form_widget(form.id_jeux, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.id_jeux) }}
        </div>

        <div class="form-group mb-3">
            {{ form_label(form.nom, 'Nom') }}
            {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.nom) }}
        </div>

        <div class="form-group mb-3">
            {{ form_label(form.prenom, 'Prénom') }}
            {{ form_widget(form.prenom, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.prenom) }}
        </div>

        <div class="form-group mb-3">
            {{ form_label(form.feedback, 'Feedback') }}
            {{ form_widget(form.feedback, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.feedback) }}
        </div>

        <button type="submit" class="btn btn-primary">Enregistrer</button>
    {{ form_end(form) }}
{% endblock %}
