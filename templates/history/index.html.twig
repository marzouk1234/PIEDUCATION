{% extends 'base.html.twig' %}

{% block title %}Historique des Actions{% endblock %}

{% block body %}
    <h1 style="color: #333;">Historique des Actions</h1>
    
    <table style="width: 100%; border-collapse: collapse; margin: 25px 0; font-size: 0.9em; min-width: 400px; border-radius: 5px 5px 0 0; overflow: hidden; box-shadow: 0 0 20px rgba(0, 0, 0, 0.15);">
        <thead>
            <tr style="background-color:rgb(109, 124, 129); color: #ffffff; text-align: left; font-weight: bold;">
                <th style="padding: 12px 15px;">Action</th>
                <th style="padding: 12px 15px;">Évaluation</th>
                <th style="padding: 12px 15px;">Détails</th>
                <th style="padding: 12px 15px;">Date</th>
            </tr>
        </thead>
        <tbody>
            {% for entry in historique %}
                <tr style="border-bottom: 1px solid #dddddd;">
                    <td style="padding: 12px 15px;">{{ entry.action }}</td>
                    <td style="padding: 12px 15px;">{{ entry.evaluationId }}</td>
                    <td style="padding: 12px 15px;">{{ entry.details ?: 'Aucun détail' }}</td>
                    <td style="padding: 12px 15px;">{{ entry.dateAction|date('Y-m-d H:i') }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" style="text-align: center; color: #777; padding: 12px 15px;">Aucune action enregistrée.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}