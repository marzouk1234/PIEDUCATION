{% extends 'front.html.twig' %}

{% block title %}Welcome to EduPlay{% endblock %}

{% block body %}
<div class="main-banner" id="top">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="row">
                    <div class="col-lg-6 align-self-center">
                        <div class="left-content header-text wow fadeInLeft" data-wow-duration="1s" data-wow-delay="1s">
                            <h6>Welcome to EduPlay</h6>
                            <h2>Your Gateway ToLife- <em>Long E-Learning</em></h2>
                            <p>EduPlay-Your Trusted Platform For Professional E-Learning.</p>
                            {% if app.user %}
                                <li>Hello, {{ app.user.userIdentifier }}</li>
                                <li><a href="{{ path('app_logout') }}">Logout</a></li>
                            {% else %}
                            <div class="button-container">
                                <li><a href="{{ path('app_login') }}" class="btn btn-lg btn-primary">Login</a></li>
                                <li><a href="{{ path('app_register') }}" class="btn btn-lg btn-custom">Sign Up</a></li>
                            </div>
                            {% endif %}
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <div class="right-image wow fadeInRight" data-wow-duration="1s" data-wow-delay="0.5s">
                            <img src="assetsf/images/banner-right-image.png" alt="team meeting">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add this CSS in your template or CSS file -->
<style>
    .btn {
        padding: 12px 30px;
        font-size: 18px;
        font-weight: bold;
        border-radius: 5px;
        transition: all 0.3s ease;
        margin-bottom: 10px; /* Add margin between buttons */
        display: inline-block;
        width: 100%; /* Ensure buttons are of the same size */
    }

    .btn-primary {
        background-color: #007bff;
        border: 2px solid #007bff;
        color: white;
    }

    .btn-primary:hover {
        background-color: #0056b3;
        border-color: #0056b3;
        transform: scale(1.1);
    }

    /* Sign Up Button Color */
    .btn-custom {
        background-color: #ff6347; /* Tomato color */
        border: 2px solid #ff6347;
        color: white;
    }

    .btn-custom:hover {
        background-color: #e5533c; /* Darker Tomato color */
        border-color: #e5533c;
        transform: scale(1.1);
    }

    /* Adjust container to ensure both buttons appear side by side */
    .button-container li {
        display: inline-block;
        margin-right: 10px;
    }
</style>

{% endblock %}
